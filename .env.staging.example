# Use a completely separate Supabase project for staging.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_STAGING_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_STAGING_SERVICE_ROLE_KEY

CRON_SECRET=STAGING_ONLY_LONG_RANDOM_VALUE
IMPORT_SECRET=STAGING_ONLY_DIFFERENT_RANDOM_VALUE
ROTACLOUD_API_KEY=YOUR_STAGING_ROTACLOUD_API_KEY
NEXT_PUBLIC_DEMO_MODE=false

# Delivery sandbox. Keep the recipient override set until UAT is signed off.
REMINDER_WEBHOOK_URL=https://automation.example.com/staging-kitchen-reminders
REMINDER_RECIPIENT_OVERRIDE=your-own-test-email@example.com

# Used only by `npm run test:connector` on an administrator's machine.
STAGING_APP_URL=https://YOUR_STAGING_APP.example.com
STAGING_ORGANISATION_ID=00000000-0000-4000-8000-000000000000
STAGING_SITE_ID=00000000-0000-4000-8000-000000000001
