 src/app/(app)/settings/sites/page.tsx     |   2 +-
 src/app/(app)/summary/page.tsx            |   2 +-
 src/app/auth/confirm/page.tsx             |   2 +-
 src/app/auth/forgot-password/page.tsx     |   2 +-
 src/app/auth/set-password/page.tsx        |   2 +-
 src/app/globals.css                       | 318 +++++++++++++++-------
 src/app/layout.tsx                        |   9 +
 src/app/login/page.tsx                    |   2 +-
 src/components/dashboard/cost-chart.tsx   |   6 +-
 13 files changed, 250 insertions(+), 123 deletions(-)

