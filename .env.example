# Browser-safe Supabase values
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Server only — never prefix these with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
CRON_SECRET=GENERATE_A_LONG_RANDOM_VALUE
IMPORT_SECRET=GENERATE_A_DIFFERENT_LONG_RANDOM_VALUE

# Optional, server-only read access for rota team and availability sync.
# Never prefix with NEXT_PUBLIC_. The application does not publish RotaCloud shifts.
ROTACLOUD_API_KEY=YOUR_ROTACLOUD_API_KEY

# Optional Operations Intelligence review. Keep the API key server-side.
# OPENAI_MODEL is optional; the app defaults to gpt-5-mini.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-5-mini

# Optional nearby-event signals. Weather defaults to central Manchester.
TICKETMASTER_API_KEY=YOUR_TICKETMASTER_API_KEY
ROTA_EVENTS_CITY=Manchester
ROTA_WEATHER_LATITUDE=53.4808
ROTA_WEATHER_LONGITUDE=-2.2426

# Optional: receives reminder JSON and delivers email/Slack/Teams via your chosen provider
REMINDER_WEBHOOK_URL=https://automation.example.com/kitchen-reminders

# Optional safety override. When set, every webhook payload is addressed to this email.
# Keep this set in UAT until scheduled reminders have been signed off.
REMINDER_RECIPIENT_OVERRIDE=uat-recipient@example.com

# Set true only for a non-production demonstration deployment
NEXT_PUBLIC_DEMO_MODE=false
